{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "skipRenderingPages": ["/auth", "/facturas", "/select-company", "/settings"],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "URL de Supabase",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "Llave anónima de Supabase",
    "NEXT_PUBLIC_BASEAPI_URL": "URL base de BaseAPI",
    "BASEAPI_API_KEY": "API Key de BaseAPI",
    "SESSION_SECRET": "Secret para sesiones",
    "NEXT_PUBLIC_SESSION_TIMEOUT": "Timeout de sesión"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
