# BaseAPI.cl Configuration
NEXT_PUBLIC_BASEAPI_URL=https://api.baseapi.cl/v1
BASEAPI_API_KEY=your_baseapi_api_key_here

# Supabase Configuration (for user management)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=1800000
NODE_ENV=development

# Security
SESSION_SECRET=your_session_secret_here_min_32_chars

# Optional: Database (SQLite local cache)
# DATABASE_URL=file:./dte_cache.db
